# AI provider: "claude" or "mimo"
# AI_PROVIDER=claude

# --- Claude Code config ---
# Claude Code binary path (optional - auto-detect if empty)
# CLAUDE_PATH=
# Claude Code model override (optional)
# CLAUDE_MODEL=claude-sonnet-4-6-20250514

# --- MiMoCode config ---
# MiMoCode binary path (optional - auto-detect if empty)
# MIMO_PATH=
# MiMoCode model override (optional)
# MIMO_MODEL=mimo/mimo-auto

# --- Workspace ---
# Claude Code working directory (default: project root when empty)
# WORKSPACE_DIR=C:\

# --- WeChat API (do not change) ---
ILINK_BASE_URL=https://ilinkai.weixin.qq.com
CDN_BASE_URL=https://novac2c.cdn.weixin.qq.com/c2c

# --- Webhook (optional) ---
# WEBHOOK_TOKEN=my-secret
